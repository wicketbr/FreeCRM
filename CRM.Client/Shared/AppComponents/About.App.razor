@implements IDisposable
@using Humanizer
@inject BlazorDataModel Model

@{
    // This component is used to display application-specific items on the about page.

    <h1 class="page-title">
        <Icon Name="About" />
        About freeCRM
    </h1>

    <div class="mb-2">
        A free, open-source CRM (Customer Relationship Management) system.
    </div>

    <div class="mb-2">
        Use this as-is to run your business, or use this as a starting point
        for building your own application on this framework.
    </div>
}

@code {
    [Parameter] public bool InDialog { get; set; }

    public void Dispose()
    { 
        Model.OnChange -= StateHasChanged;
    }

    protected override void OnInitialized()
    {
        Model.OnChange += StateHasChanged;
    }
}